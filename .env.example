# Supabase project (Dashboard -> Project Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Direct Postgres connection for migrations
# (Dashboard -> Connect -> Session pooler URI, includes the database password)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Server
PORT=3000
