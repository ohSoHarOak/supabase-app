# ─────────────────────────────────────────────────────────────────────────
#  Local .env  =  your separate Supabase **TEST** project.
#
#  Everything local — `npm run dev`, `npm test`, `npm run migrate` — reads
#  this file. Point it at the TEST project and local work can never touch
#  production. PRODUCTION credentials live ONLY in the Render dashboard,
#  never in a file here.
#
#  To apply a migration to prod on purpose, see TEST_PROJECT_AND_MIGRATIONS.md
#  (you keep prod creds in a gitignored .env.prod and target it explicitly).
# ─────────────────────────────────────────────────────────────────────────

# Supabase TEST project (Dashboard -> Project Settings -> API)
SUPABASE_URL=https://YOUR_TEST_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-test-anon-key
SUPABASE_SERVICE_KEY=your-test-service-role-key

# Direct Postgres connection for migrations — the TEST project's
# (Dashboard -> Connect -> Session pooler URI; includes the database password)
DATABASE_URL=postgresql://postgres.YOUR_TEST_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Stripe — TEST MODE keys (Dashboard -> Developers -> API keys)
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Webhook signing secret (Dashboard -> Developers -> Webhooks -> your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Server
PORT=3000
